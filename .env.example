# PDF 论文翻译助手 配置模板

# Poe API Key (可选，前端配置优先，但某些环境下后端调用可能需要)
POE_API_KEY=your_poe_api_key_here

# 数据库连接地址
# 默认使用本地 SQLite: sqlite:///translations.db
# PostgreSQL 示例: postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///translations.db

# 提取标题的提示词
TITLE_PROMPT=请查看附加的 PDF 文档，提取论文标题。标题可能由多行组成，仅返回标题文本，不要翻译或添加其他注释。

# 默认使用的 Poe 模型（上传/继续/追问都可由前端覆盖）
POE_MODEL=GPT-5.2-Instant

# 初始翻译请求的提示词
INITIAL_PROMPT=翻译这篇论文，每次翻译一章（摘要单独算一章）。摘要、章节用 1 级标题，子章节为 2 级标题。当我说“继续”时翻译下一章，直到结束。请先翻译摘要。

# 是否启用只读模式 (true/false)
# 开启后禁用上传、继续翻译和自定义对话功能
READ_ONLY=false

# 异步任务 worker 数量（上传/续翻/追问）
ASYNC_JOB_WORKERS=2

# Agent 提交流水线结果到后端数据库时使用的鉴权 Token（通过 x-agent-token 传递）
AGENT_INGEST_TOKEN=replace_with_strong_random_token
